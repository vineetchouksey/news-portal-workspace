{
  "name": "news-portal-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build-ui-kit": "ng build ui-kit",
    "start-shell": "ng serve shell",
    "start-news-mfe": "ng serve news-mfe --port 4201",
    "start-stock-mfe": "ng serve stock-mfe --port 4202",
    "start-book-mfe": "ng serve book-mfe --port 4203",
    "start-dashboard-mfe": "ng serve dashboard-mfe --port 4204",
    "start": "concurrently \"npm run start-shell\" \"npm run start-news-mfe\" \"npm run start-stock-mfe\" \"npm run start-book-mfe\" \"npm run start-dashboard-mfe\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "prestart": "ng build ui-kit"
  },
  "private": true,
  "packageManager": "npm@11.2.0",
  "dependencies": {
    "@angular-architects/module-federation": "^21.2.1",
    "@angular/animations": "^21.2.2",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/signals": "^21.0.1",
    "@primeuix/themes": "^2.0.3",
    "@softarc/native-federation-node": "^2.0.10",
    "chart.js": "^4.3.0",
    "es-module-shims": "^1.5.12",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^21.2.1",
    "@angular-devkit/build-angular": "^21.2.2",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@softarc/native-federation": "~3.5.1",
    "@softarc/native-federation-runtime": "~3.5.1",
    "concurrently": "^9.2.1",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
